{
  "name": "growth-hach",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint:eslint": "eslint . --ext .js,.mjs,.cjs,.svelte --max-warnings=0",
    "lint": "pnpm check --fail-on-warnings && pnpm run lint:eslint && pnpm run format:check",
    "lint:fix": "pnpm format",
    "audit": "node scripts/audit-check.mjs",
    "check:full": "pnpm lint && pnpm build && pnpm run audit",
    "qa": "pnpm run check:full",
    "qa:local": "pnpm lint:fix && pnpm qa",
    "auth:generate": "pnpm dlx @better-auth/cli@1.4.21 generate --config src/lib/auth.ts",
    "db:generate": "node scripts/run-drizzle.mjs generate",
    "db:push": "node scripts/run-drizzle.mjs push",
    "db:migrate": "node scripts/run-drizzle.mjs migrate",
    "db:reset": "node --experimental-strip-types scripts/db-reset.ts",
    "db:seed": "node --experimental-strip-types scripts/seed-db.ts",
    "db:generate:prod": "APP_ENV=production node scripts/run-drizzle.mjs generate",
    "db:push:prod": "APP_ENV=production node scripts/run-drizzle.mjs push",
    "db:migrate:prod": "APP_ENV=production node scripts/run-drizzle.mjs migrate",
    "db:reset:prod": "APP_ENV=production node --experimental-strip-types scripts/db-reset.ts",
    "db:reset:migrate": "pnpm run db:reset && pnpm run db:migrate",
    "db:reset:migrate:prod": "pnpm run db:reset:prod && pnpm run db:migrate:prod",
    "db:seed:prod": "APP_ENV=production node --experimental-strip-types scripts/seed-db.ts",
    "db:status:prod": "APP_ENV=production node --experimental-strip-types scripts/db-status.ts",
    "db:query": "node --experimental-strip-types scripts/db-query.ts",
    "db:query:prod": "APP_ENV=production node --experimental-strip-types scripts/db-query.ts",
    "db:status": "node --experimental-strip-types scripts/db-status.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-vercel": "^6.3.1",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.13.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.0.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.1",
    "better-auth": "1.4.21",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "0.41.0",
    "heic-to": "^1.4.2",
    "lucide-svelte": "^0.562.0",
    "motion": "^12.35.1",
    "postgres": "^3.4.5",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.5"
  }
}
